{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "baseUrl": ".",
        "rootDir": "src",
        "outDir": "dist",
        "noEmit": false,
        "paths": {
            "@/*": ["src/*"]
        }
    },
    "include": ["src", "src/shared/types", "src/shared/utils"],
    "exclude": ["**/*.test.ts", "**/*.spec.ts", "src/tests"]
}
