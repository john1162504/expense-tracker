// tsconfig.json for server app

{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "baseUrl": ".",
        "rootDir": "src",
        "outDir": "dist",
        "noEmit": false,
        "paths": {
            "@/*": ["src/*"],
            "@expense-tracker/shared": ["../../packages/shared/dist"]
        }
    },
    "references": [{ "path": "../../packages/shared" }],

    "include": ["src"]
}
