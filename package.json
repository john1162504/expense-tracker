{
    "private": true,
    "name": "expense-tracker",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "test:server": "npm run test -w @expense-tracker/server",
        "dev:server": "npm run dev -w @expense-tracker/server",
        "dev:client": "npm run dev -w @expense-tracker/client",
        "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\""
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "typescript": "^5.2.2"
    },
    "dependencies": {
        "cookie-parser": "^1.4.7"
    }
}
