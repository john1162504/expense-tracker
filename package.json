{
    "private": true,
    "name": "expense-tracker",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build": "tsc -b",
        "postbuild": "tsc-alias -p apps/server/tsconfig.json && tsc-alias -p packages/shared/tsconfig.json",
        "start:server": "npm run start -w @expense-tracker/server",
        "start:client": "npm run start -w @expense-tracker/client",
        "start": "concurrently \"npm run start:server\" \"npm run start:client\"",
        "test:server": "npm run test -w @expense-tracker/server",
        "dev:server": "npm run dev -w @expense-tracker/server",
        "dev:client": "npm run dev -w @expense-tracker/client",
        "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\""
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "typescript": "^5.2.2"
    },
    "dependencies": {
        "cookie-parser": "^1.4.7"
    }
}
